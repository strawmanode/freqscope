# Local server-only feed identity.
# Required: replace these placeholders before using the live aircraft feed.
# Use your own name and a real contact email.
AIRCRAFT_FEED_APPLICATION=YourName
AIRCRAFT_FEED_CONTACT=your-email@example.com

# Optional overrides. Use these if you want exact header values.
# AIRCRAFT_FEED_USER_AGENT=YourName/0.1 (your-email@example.com)
# AIRCRAFT_FEED_X_APPLICATION=YourName
# AIRCRAFT_FEED_X_CONTACT=your-email@example.com

# Optional JSON object merged into upstream aircraft feed request headers.
# AIRCRAFT_FEED_EXTRA_HEADERS_JSON={"X-Example":"value"}
